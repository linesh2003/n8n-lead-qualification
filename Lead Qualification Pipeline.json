      "position": [
        0,
        0
      ],
      "id": "9a6bf327-a7aa-4772-87f1-fc93eaac6b10",
      "name": "Webhook",
      "webhookId": "152ad644-e8d0-44a7-a820-9fce6d433fce"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || $input.item.json;\n\nconst name = String(body.name || '').trim();\nconst email = String(body.email || '').trim();\nconst company = String(body.company || '').trim();\nconst message = String(body.message || '').trim();\nconst budget = String(body.budget || '').trim();\nconst timeline = String(body.timeline || '').trim();\nconst source = String(body.source || 'webhook').trim();\n\nconst emailValid = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\n\nlet completeness = 0;\nif (name) completeness += 20;\nif (emailValid) completeness += 25;\nif (company) completeness += 15;\nif (message.length >= 10) completeness += 25;\nif (budget) completeness += 10;\nif (timeline) completeness += 5;\n\nreturn [{\n  json: {\n    name: name || 'Unknown',\n    email: emailValid ? email : 'invalid',\n    company: company || 'Not specified',\n    message: message || 'No message provided',\n    budget: budget || 'Not specified',\n    timeline: timeline || 'Not specified',\n    source: source,\n    completeness: completeness,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "8a4fc2fc-c34e-4db9-9660-fe3eb2e9aebf",
      "name": "Data Validator"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this lead:\n\nData Completeness Score: {{ $json.completeness }}/100\n\nName: {{ $json.name }}\nEmail: {{ $json.email }}\nCompany: {{ $json.company }}\nMessage: {{ $json.message }}\nBudget: {{ $json.budget }}\nTimeline: {{ $json.timeline }}",
        "messages": {
          "messageValues": [
            {
              "message": "=You are an expert lead qualification analyst for a B2B automation company. Your job is to analyze incoming lead data and assign a quality score from 1 to 100.\n\nScoring Criteria:\n- Message specificity and detail (0-25 points)\n- Budget alignment and clarity (0-20 points)\n- Timeline urgency (0-15 points)\n- Company relevance (0-15 points)\n- Data completeness provided separately (0-15 points)\n- Communication professionalism (0-10 points)\n\nCategory Thresholds:\n- Hot: 80-100\n- Warm: 50-79\n- Cold: 1-49\n\nYou MUST respond in EXACTLY this format and nothing else:\nSCORE: [number]\nCATEGORY: [Hot/Warm/Cold]\nREASON: [one sentence explanation]"
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        416,
        0
      ],
      "id": "3a9a819a-69f5-44bf-8991-4bb3aad7b62d",
      "name": "AI Lead Scorer"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 3
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('AI Lead Scorer').item.json.text }}",
                    "rightValue": "CATEGORY: Hot",
                    "operator": {
                      "type": "string",
