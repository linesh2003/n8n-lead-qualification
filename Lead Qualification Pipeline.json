        "subject": "=HOT LEAD: {{ $('Data Validator').item.json.name }} from {{ $('Data Validator').item.json.company }}",
        "message": "=<h2>Hot Lead Alert</h2>\n<table style=\"border-collapse:collapse;width:100%;font-family:Arial;\">\n<tr><td style=\"padding:8px;border:1px solid #ddd;\"><b>Name</b></td><td style=\"padding:8px;border:1px solid #ddd;\">{{ $('Data Validator').item.json.name }}</td></tr>\n<tr><td style=\"padding:8px;border:1px solid #ddd;\"><b>Email</b></td><td style=\"padding:8px;border:1px solid #ddd;\">{{ $('Data Validator').item.json.email }}</td></tr>\n<tr><td style=\"padding:8px;border:1px solid #ddd;\"><b>Company</b></td><td style=\"padding:8px;border:1px solid #ddd;\">{{ $('Data Validator').item.json.company }}</td></tr>\n<tr><td style=\"padding:8px;border:1px solid #ddd;\"><b>Budget</b></td><td style=\"padding:8px;border:1px solid #ddd;\">{{ $('Data Validator').item.json.budget }}</td></tr>\n<tr><td style=\"padding:8px;border:1px solid #ddd;\"><b>Timeline</b></td><td style=\"padding:8px;border:1px solid #ddd;\">{{ $('Data Validator').item.json.timeline }}</td></tr>\n<tr><td style=\"padding:8px;border:1px solid #ddd;\"><b>Message</b></td><td style=\"padding:8px;border:1px solid #ddd;\">{{ $('Data Validator').item.json.message }}</td></tr>\n<tr><td style=\"padding:8px;border:1px solid #ddd;\"><b>AI Analysis</b></td><td style=\"padding:8px;border:1px solid #ddd;white-space:pre-wrap;\">{{ $('AI Lead Scorer').item.json.text }}</td></tr>\n</table>",
